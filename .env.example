# .env - Variables de Entorno para Librería Bartleby
# Copia este archivo a .env y actualiza los valores según tu entorno

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────────

# Django
ENV_ENVIRONMENT=development
DEBUG=False
DEBUG=True
SECRET_KEY=tu-clave-secreta-aqui-minimo-50-caracteres-aleatorios

# Hosts permitidos (separados por comas)
ALLOWED_HOSTS=localhost,127.0.0.1,libreria-bartleby.local

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────

DB_ENGINE=django.db.backends.postgresql
DB_NAME=bartleby_db
DB_USER=postgres
DB_PASSWORD=tu-password-aqui
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# CORREO (EMAIL)
# ─────────────────────────────────────────────────────────────────────────────

# Gmail: SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-app

# Para desarrollo, usa console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIOS EXTERNOS
# ─────────────────────────────────────────────────────────────────────────────

# Google Books API (opcional, para búsqueda ISBN)
GOOGLE_BOOKS_API_KEY=tu-api-key-aqui
RESEND_API_KEY=tu-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD - Protecciones Adicionales
# ─────────────────────────────────────────────────────────────────────────────

# HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Rate Limiting
RATELIMIT_ENABLE=True
# En producción, usar un backend más eficiente (Redis)
RATELIMIT_USE_CACHE=default

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING & MONITOREO
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
SENTRY_DSN=
